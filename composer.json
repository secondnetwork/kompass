{
    "name": "secondnetwork/kompass",
    "description": "Kompass A Laravel CMS",
    "keywords": [
        "laravel",
        "admin",
        "panel",
        "cms"
    ],
    "homepage": "https://github.com/secondnetwork/kompass",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Andreas Farah",
            "email": "github@secondnetwork.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "intervention/image": "^3.9.1 || ^4.0.0",
        "livewire/livewire": "^4.2.1",
        "secondnetwork/blade-tabler-icons": "^3.40.1",
        "spatie/laravel-permission": "^7.2.4",
        "log1x/laravel-webfonts": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Secondnetwork\\Kompass\\": "src",
            "Secondnetwork\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Secondnetwork\\Kompass\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Secondnetwork\\Kompass\\KompassServiceProvider"
            ],
            "aliases": {
                "Kompass": "Secondnetwork\\Kompass\\KompassFacade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "rector/rector": "^2.0",
        "driftingly/rector-laravel": "^2.0"
    }
}
